# ─────────────────────────────────────────────────────────
# Space Wellness Studio — Environment Variables
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────

# Supabase (get from Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose

# Resend (email) — resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx
STUDIO_EMAIL=hello@spacewellness.ca               # your verified sender

# Twilio (SMS) — optional, add later
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+16475550000                   # your Twilio number

# App URL (used for redirects in auth emails)
NEXT_PUBLIC_SITE_URL=https://spacewellness.ca
